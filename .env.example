# 질병 아틀라스 — 환경변수 예시. 실제 값은 .env 에 두세요(.gitignore 처리됨).

# Neon Postgres 연결 문자열 — Vercel 마켓플레이스에서 Neon DB 생성 시 자동 주입.
# 서버리스에선 풀링 엔드포인트(호스트에 -pooler 포함)를 사용할 것.
# 로컬 개발은 Neon의 dev 브랜치 커넥션 스트링을 권장.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# 관리자(/admin) 단일 비밀번호 — 반드시 강력한 값으로 변경.
ADMIN_PASSWORD="change-me"
